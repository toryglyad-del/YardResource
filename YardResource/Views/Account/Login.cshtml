@{
    ViewData["Title"] = "Вход в систему";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Вход — ООО Ярд Ресурс</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
            body {
                background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
            }
            .login-card {
                background: white;
                border-radius: 16px;
                padding: 40px;
                width: 100%;
                max-width: 420px;
                box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            }
            .company-logo {
                text-align: center;
                margin-bottom: 30px;
            }
            .company-logo h2 {
                color: #0f3460;
                font-weight: 700;
                font-size: 1.5rem;
            }
            .company-logo p {
                color: #666;
                font-size: 0.9rem;
            }
            .btn-login {
                background: #0f3460;
                border: none;
                width: 100%;
                padding: 12px;
                border-radius: 8px;
                font-size: 1rem;
                font-weight: 600;
            }
            .btn-login:hover {
                background: #16213e;
            }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="company-logo">
            <h2>ООО «Ярд Ресурс»</h2>
            <p>Система повышения квалификации</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <form method="post" action="/Account/Login">
            <div class="mb-3">
                <label class="form-label fw-semibold">Email</label>
                <input type="email" name="email" class="form-control form-control-lg"
                       placeholder="example@yardresource.ru" required />
            </div>
            <div class="mb-4">
                <label class="form-label fw-semibold">Пароль</label>
                <input type="password" name="password" class="form-control form-control-lg"
                       placeholder="Введите пароль" required />
            </div>
            <button type="submit" class="btn btn-primary btn-login">
                Войти в систему
            </button>
        </form>

        <div class="text-center mt-3">
            <small class="text-muted">© 2025 ООО «Ярд Ресурс»</small>
        </div>
    </div>
</body>
</html>